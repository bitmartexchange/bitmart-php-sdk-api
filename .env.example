# BitMart PHP SDK - unit test credentials
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# tests/TestConfig.php resolves each value with the precedence:
#     .env file  >  system environment variable (getenv)  >  defaults in TestConfig.php

BITMART_API_KEY=your_api_key
BITMART_SECRET_KEY=your_secret_key
BITMART_MEMO=your_memo

# Optional: override the API host for BOTH spot and futures tests.
# Leave commented/empty to use the defaults
#   spot    -> https://api-cloud.bitmart.com
#   futures -> https://api-cloud-v2.bitmart.com
# Note: setting a single URL applies to both, so only set this when you
# really want to point every test at one specific host (e.g. a test env).
# BITMART_API_URL=
